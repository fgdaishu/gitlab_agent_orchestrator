GITLAB_URL=http://<gitlab-host>/gitlab
GITLAB_TOKEN=replace-with-gitlab-access-token
GITLAB_WEBHOOK_SECRET=replace-with-webhook-secret

# The requested test default is opencode.
DEFAULT_AGENT=opencode
AGENT_TRIGGER_LABEL=agent:opencode

DATABASE_URL=sqlite:///./orchestrator.sqlite3
WORKSPACE_ROOT=./workspaces
JOB_POLL_INTERVAL_SECONDS=2
JOB_TIMEOUT_SECONDS=3600
GIT_AUTHOR_NAME=agent-bot
GIT_AUTHOR_EMAIL=agent-bot@example.local

# Optional command overrides.
OPENCODE_COMMAND=opencode
CODEX_COMMAND=codex
GEMINI_COMMAND=gemini

# Execution backend. docker_project runs all project jobs inside one long-lived
# Docker container per GitLab project.
AGENT_EXECUTION_BACKEND=docker_project

# docker_project backend settings.
SANDBOX_DOCKER_IMAGE=gitlab-agent-sandbox:latest
SANDBOX_BOOTSTRAP_VERSION=1
SANDBOX_BOOTSTRAP_COMMAND=:
SANDBOX_USER=
SANDBOX_OPENCODE_COMMAND=opencode
SANDBOX_OPENCODE_MODEL=opencode/big-pickle
SANDBOX_AGENT_IDLE_TIMEOUT_SECONDS=120
SANDBOX_AGENT_MAX_AFTER_CHANGES_SECONDS=180
SANDBOX_CODEX_COMMAND=codex
SANDBOX_GEMINI_COMMAND=gemini
SANDBOX_PASS_ENV=OPENAI_API_KEY,ANTHROPIC_API_KEY,GEMINI_API_KEY,GOOGLE_API_KEY,GOOGLE_GENAI_USE_VERTEXAI,GOOGLE_GENAI_USE_GCA

# Optional agent API keys. Leave blank when OAuth or a free/default model is used.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
